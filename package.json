{
  "name": "name-o-tron-9000",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "bundle:linux": "bash scripts/build-linux-bundles.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:icons": "node scripts/generate-icons.js",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:types": "tsc --noEmit",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test:types && npm run test && npm run test:rust",
    "mock:plex": "node tests/mock-plex/mock-plex-server.cjs",
    "mock:start": "node tests/mock-plex/bin/mock-harness.mjs start",
    "mock:stop": "node tests/mock-plex/bin/mock-harness.mjs stop",
    "mock:status": "node tests/mock-plex/bin/mock-harness.mjs status",
    "mock:setup-media": "node tests/mock-plex/bin/mock-reset.mjs --mode media --media-root ./test_media",
    "mock:write-mappings": "node tests/mock-plex/bin/mock-reset.mjs --mode mappings --media-root ./test_media --mappings-out ./tests/mock-plex/generated/mock-path-mappings.json",
    "mock:setup": "node tests/mock-plex/bin/mock-reset.mjs --media-root ./test_media --mappings-out ./tests/mock-plex/generated/mock-path-mappings.json",
    "mock:reset": "node tests/mock-plex/bin/mock-reset.mjs --media-root ./test_media --mappings-out ./tests/mock-plex/generated/mock-path-mappings.json",
    "mock:verify": "node tests/mock-plex/bin/mock-verify.mjs --base-url http://localhost:32400 --media-root ./test_media"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0",
    "autoprefixer": "^10.4.21",
    "express": "^5.2.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.9",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "qs": "6.15.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.33.5": true
  }
}
