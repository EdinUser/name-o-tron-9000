{
  "name": "name-o-tron-9000",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:icons": "node scripts/generate-icons.js",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:types": "tsc --noEmit",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test:types && npm run test && npm run test:rust",
    "mock:plex": "node tests/mock-plex/mock-plex-server.cjs",
    "mock:setup-media": "bash tests/mock-plex/bin/setup-test-media.sh --out ./test_media",
    "mock:write-mappings": "bash tests/mock-plex/bin/write-path-mappings.sh --media-root ./test_media --out ./tests/mock-plex/generated/mock-path-mappings.json",
    "mock:setup": "npm run mock:setup-media && npm run mock:write-mappings",
    "mock:verify": "bash tests/mock-plex/bin/verify-mock-plex.sh --base-url http://localhost:32400 --media-root ./test_media"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0",
    "autoprefixer": "^10.4.21",
    "express": "^5.1.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.9",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
