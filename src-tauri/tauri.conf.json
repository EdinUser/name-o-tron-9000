{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "name-o-tron-9000",
  "version": "0.2.0",
  "identifier": "com.lenivec.name-o-tron-9000",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "name-o-tron-9000",
        "width": 1300,
        "height": 800,
        "minWidth": 1300,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Kirilov.dev",
    "homepage": "https://name-o-tron.kirilov.dev/",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "category": "Utility",
    "shortDescription": "Rename local media files using Plex metadata with preview, safety checks, and rollback.",
    "longDescription": "Name-o-Tron 9000 is a cross-platform desktop app that renames local media files using Plex metadata. It provides preview-first workflows, safety checks, rollback logging, subtitle handling, and path mapping tools.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/metainfo/com.lenivec.name-o-tron-9000.metainfo.xml": "linux/com.lenivec.name-o-tron-9000.metainfo.xml",
          "/usr/share/metainfo/com.lenivec.name-o-tron-9000.appdata.xml": "linux/com.lenivec.name-o-tron-9000.metainfo.xml",
          "/usr/share/icons/hicolor/scalable/apps/name-o-tron-9000.svg": "icons/name-o-tron-9000.svg"
        }
      },
      "deb": {
        "desktopTemplate": "linux/com.lenivec.name-o-tron-9000.desktop.hbs",
        "files": {
          "/usr/share/metainfo/com.lenivec.name-o-tron-9000.metainfo.xml": "linux/com.lenivec.name-o-tron-9000.metainfo.xml",
          "/usr/share/metainfo/com.lenivec.name-o-tron-9000.appdata.xml": "linux/com.lenivec.name-o-tron-9000.metainfo.xml",
          "/usr/share/icons/hicolor/scalable/apps/name-o-tron-9000.svg": "icons/name-o-tron-9000.svg"
        }
      },
      "rpm": {
        "desktopTemplate": "linux/com.lenivec.name-o-tron-9000.desktop.hbs",
        "files": {
          "/usr/share/metainfo/com.lenivec.name-o-tron-9000.metainfo.xml": "linux/com.lenivec.name-o-tron-9000.metainfo.xml",
          "/usr/share/icons/hicolor/scalable/apps/name-o-tron-9000.svg": "icons/name-o-tron-9000.svg"
        },
        "release": "1"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
